# ─────────────────────────────────────────────────────────────────
#  UPLEVEL SERVICES — Environment Variables
#  Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── Contact Form (Required for /api/contact) ──
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
NOTIFICATION_EMAIL=hello@uplevelservices.co
MAKE_WEBHOOK_URL=https://hook.us1.make.com/xxxxxxxxxxxx

# ── AI Voice Widget (Optional — for future Vapi integration) ──
NEXT_PUBLIC_VAPI_KEY=
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# ── Analytics (Optional) ──
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
